#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/robots/clearpath/pr2/protos/Pr2.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/humans/pedestrian/protos/Pedestrian.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/containers/protos/WoodenBox.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/robots/softbank/nao/protos/Shelves.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/appearances/protos/RoughConcrete.proto"

WorldInfo {
  title "Simple Ethics Test World"
  basicTimeStep 16
}
Viewpoint {
  orientation -0.5 0.5 0.7 1.5
  position 10 -15 15
}
TexturedBackground {}
TexturedBackgroundLight {}

RectangleArena {
  floorSize 20 20
  floorAppearance RoughConcrete { textureTransform TextureTransform { scale 5 5 } }
}

# --- Robot ---
Pr2 {
  translation -8 -5 0
  controller "pr2_autonomous_ethics"
  supervisor TRUE
}

# --- Target Shelf & Box ---
Shelves {
  translation 0 -5 0
  rotation 0 0 1 3.14159
  name "target_shelf"
}
WoodenBox {
  translation 0.02 -5 0.62
  name "mission_target_box"
  size 0.2 0.2 0.2
}

# --- Pedestrian (to test ethics reduction) ---
Pedestrian {
  translation -4 -5 0
  name "human_test"
}
