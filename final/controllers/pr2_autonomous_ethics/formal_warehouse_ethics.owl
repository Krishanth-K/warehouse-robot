<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://eras-nep.org/formal_warehouse.owl"
         xmlns="http://eras-nep.org/formal_warehouse.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://eras-nep.org/formal_warehouse.owl"/>

<owl:ObjectProperty rdf:about="#recognizes">
  <rdfs:domain rdf:resource="#Agent"/>
  <rdfs:range rdf:resource="#Situation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#executes">
  <rdfs:domain rdf:resource="#Agent"/>
  <rdfs:range rdf:resource="#PlanAction"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Agent">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Robot">
  <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<owl:Class rdf:about="#Situation">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#HumanNearSituation">
  <rdfs:subClassOf rdf:resource="#Situation"/>
</owl:Class>

<owl:Class rdf:about="#PlanAction">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#ReducedVelocityAction">
  <rdfs:subClassOf rdf:resource="#PlanAction"/>
</owl:Class>

<owl:Class rdf:about="#NormalVelocityAction">
  <rdfs:subClassOf rdf:resource="#PlanAction"/>
</owl:Class>

<owl:Class rdf:about="#EmergencyStopAction">
  <rdfs:subClassOf rdf:resource="#PlanAction"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#pr2_robot">
  <rdf:type rdf:resource="#Robot"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#reduced_velocity_action">
  <rdf:type rdf:resource="#ReducedVelocityAction"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#normal_velocity_action">
  <rdf:type rdf:resource="#NormalVelocityAction"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#emergency_stop_action">
  <rdf:type rdf:resource="#EmergencyStopAction"/>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#r"/>

<swrl:Variable rdf:about="urn:swrl#s"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Robot"/>
          <swrl:argument1 rdf:resource="urn:swrl#r"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#recognizes"/>
              <swrl:argument1 rdf:resource="urn:swrl#r"/>
              <swrl:argument2 rdf:resource="urn:swrl#s"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:ClassAtom>
                  <swrl:classPredicate rdf:resource="#HumanNearSituation"/>
                  <swrl:argument1 rdf:resource="urn:swrl#s"/>
                </swrl:ClassAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#executes"/>
          <swrl:argument1 rdf:resource="urn:swrl#r"/>
          <swrl:argument2 rdf:resource="#reduced_velocity_action"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
