Prefix: owl:  <http://www.w3.org/2002/07/owl#>
Prefix: rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
Prefix: rdfs: <http://www.w3.org/2000/01/rdf-schema#>
Prefix: xml:  <http://www.w3.org/XML/1998/namespace>
Prefix: xsd:  <http://www.w3.org/2001/XMLSchema#>

# is there a way of defining the sqwrl prefix so that the full iri is not required for each rule?
# Prefix: sqwrl: <http://sqwrl.stanford.edu/ontologies/built-ins/3.4/sqwrl.owl>
# Prefix: sqwrl: <http://sqwrl.stanford.edu/ontologies/built-ins/3.4/sqwrl.owl#>
# Prefix: sqwrl: <http://sqwrl.stanford.edu/ontologies/built-ins/3.4/sqwrl.owl#select>
# Prefix: sqwrl: <http://sqwrl.stanford.edu/ontologies/built-ins/3.4/>

Prefix: tlo: <file://tlo#>
Prefix: nep: <file://nep>


Ontology: <file://~/Documents/AI-ontologies/ERAS-NEP-owl-manchester-axioms.owl>
Import:   <file://~/Documents/AI-ontologies/ERAS-TLO-owl-manchester-axioms.owl>
  
Annotations:
  rdfs:comment "An example mapping of ERAS-NEP CLIF axioms into OWL axioms using Manchester OWL syntax" 

AnnotationProperty: rdfs:comment

# definitions for the 52 NEP relationships
#
ObjectProperty: nep:specifies_norm_modality
		Domain: nep:EthicalTheory
		Range:  nep:Norm

ObjectProperty: nep:is_prescribed_by
		Domain: nep:Norm
		Range:  nep:EthicalTheory
		InverseOf: nep:specifies_norm_modality

ObjectProperty:	nep:subscribes_to
		Domain: nep:AgentPlan
		Range:	nep:EthicalTheory
		
ObjectProperty: nep:authorized_by
		Domain: nep:Norm
    		Range:  nep:Agent
        
ObjectProperty: nep:accepted_by
		Domain: nep:Norm
    		Range:  nep:Agent
        
ObjectProperty: nep:accommodates
		Domain: nep:Norm
    		Range:  nep:EthicalPrinciple

ObjectProperty: nep:conflicts_with
		Domain: nep:Norm
		Range:  nep:Norm

ObjectProperty: nep:caused_by
		Domain: nep:EthicalDilemma
		Range:  nep:Norm

ObjectProperty: nep:ranks_preferred_norm
		Domain: nep:DilemmaMitigationPrinciple
		Range:  nep:EthicalDilemma 
		
ObjectProperty: nep:recognizes
		Domain: nep:Agent
     		Range:  nep:Situation

ObjectProperty: nep:intends_to_realize
		Domain: nep:Agent
		Range:  nep:Situation

ObjectProperty: nep:is_involved_in
		Domain: nep:Norm
		Range:  nep:Situation
		
ObjectProperty: nep:includes
		Domain: nep:SituationPlanRepertoire
		Range:  nep:AgentPlan

ObjectProperty: nep:constrains_plans_for
		Domain: nep:EthicalTheory
		Range:  nep:SituationPlanRepertoire

ObjectProperty: nep:satisfies
		Domain: nep:AgentPlan
		Range:  nep:Norm

ObjectProperty: nep:features_described_in
		Domain: nep:Situation
		Range:  nep:SituationPlanRepertoire

ObjectProperty: nep:selects_plans_from
		Domain: nep:Agent
		Range:  nep:SituationPlanRepertoire

ObjectProperty: nep:applies
		Domain: nep:Agent
		Range:  nep:AgentPlan

ObjectProperty: nep:contains
		Domain: nep:AgentPlan
		Range:  nep:PlanAction

ObjectProperty: nep:logically_justifies
		Domain: nep:ActionRationale
		Range:  nep:PlanAction

ObjectProperty: nep:executes
		Domain: nep:Agent
		Range:  nep:PlanAction
		
ObjectProperty: nep:is_implemented_by
		Domain: nep:PlanAction
		Range:  nep:AgentAction

ObjectProperty: nep:temporarily_suspends
		Domain: nep:Derogation
		Range:  nep:Norm

ObjectProperty: nep:activates
		Domain: nep:AgentAction
		Range:  nep:Derogation

ObjectProperty: nep:deactivates
		Domain: nep:AgentAction
		Range:  nep:Derogation

ObjectProperty: nep:initiates
		Domain: nep:Agent
		Range:  tlo:AgentCommunication
		
ObjectProperty: nep:receives
		Domain: nep:Agent
		Range:  tlo:AgentCommunication
		
ObjectProperty: nep:prompts
		Domain:    nep:Situation
		Range:     tlo:AgentCommunication

ObjectProperty: nep:has_as_goal
		Domain: nep:TaskAssignment
		Range:  nep:Situation

ObjectProperty: nep:is_response_to
		Domain: nep:Answer
		Range:  nep:Query

ObjectProperty: nep:influences_norm_applicability
		Domain: nep:SocialCollection
		Range:  nep:Norm

ObjectProperty: nep:prescribes_context_for
		Domain: nep:SocialCollection
		Range:  nep:Norm

ObjectProperty: nep:assigned_to
		Domain: nep:AgentRole
		Range:  nep:Agent
		
ObjectProperty: nep:stipulates
		Domain: nep:AgentRole
		Range:  nep:Norm

ObjectProperty: nep:succeeds
		Domain:    nep:Situation
		Range:     nep:Situation

ObjectProperty: nep:precedes
 		Domain:    nep:Situation
		Range:     nep:Situation

# note: the nep ternary relationship agent_perceives_as
#       is mapped to the following two relationships
#
ObjectProperty: nep:is_perception_of
		Domain: nep:Situation
		Range:  nep:Environment

ObjectProperty: nep:is_perceived_by
		Domain: nep:Environment
		Range:  nep:Agent

ObjectProperty: nep:state
	        Domain: nep:Norm
	        Range:  nep:norm_states
	        Characteristics: Functional

ObjectProperty: nep:team_type
	        Domain: nep:Team
	        Range:  nep:team_types
	        Characteristics: Functional

ObjectProperty: nep:category
	        Domain: nep:Norm
	        Range:  nep:norm_category
	        Characteristics: Functional

DataType:      nep:string
	       EquivalentTo: xsd:string

# ObjectProperty: nep:state
#	        Domain: nep:Norm
#	        Range:  nep:string
#	        Characteristics: Functional

Class: nep:EnumDataTypes SubClassOf: tlo:EnumDataTypes

# definitions for the 40 NEP concepts
#
Class: nep:Norm  SubClassOf: tlo:Method
       		 that nep:is_prescribed_by min 1 nep:EthicalTheory
		  and nep:authorized_by min 1 nep:Agent
		  and nep:accepted_by min 0 nep:Agent
		  and nep:accommodates some nep:EthicalPrinciple
		  and nep:is_involved_in min 0 nep:Situation
#		  and inverse nep:specifies_norm_modality some nep:EthicalTheory
#		  and inverse nep:influences_norm_applicability min 1 nep:SocialCollection

Class: nep:norm_category
		SubClassOf: nep:EnumDataTypes

Class: nep:norm_states 
		SubClassOf: nep:EnumDataTypes
		
Class: nep:EthicalTheory 
		SubClassOf: tlo:Method
       			 that nep:specifies_norm_modality some nep:Norm 

Class: nep:ethical_theories 
		Annotations:
			rdfs:comment "Ethical Theory Examples",
			rdfs:comment "{virtuous, deontological, consequentialist, composite, divine_command, Buddhists_ethics, ..}" 
		SubClassOf: nep:EnumDataTypes    

		
Class: nep:VirtuousNorm         SubClassOf: nep:Norm
Class: nep:DeontologicalNorm    SubClassOf: nep:Norm
Class: nep:ConsequentialistNorm SubClassOf: nep:Norm

Class: nep:Obligation  SubClassOf: nep:DeontologicalNorm
Class: nep:Permission  SubClassOf: nep:DeontologicalNorm
Class: nep:Prohibition SubClassOf: nep:DeontologicalNorm

DisjointClasses: nep:VirtuousNorm, nep:DeontologicalNorm, nep:ConsequentialistNorm
DisjointClasses: nep:Obligation, nep:Permission, nep:Prohibition

Class: nep:EthicalDilemma SubClassOf: tlo:Situation
       			  that nep:caused_by min 2 nep:Norm

Class: nep:DilemmaMitigationPrinciple SubClassOf: tlo:Method
Class: nep:EthicalPrinciple           SubClassOf: tlo:Method
Class: nep:ActionRationale 	      SubClassOf: tlo:Method

Class: nep:ethical_principles 
       Annotations:
			rdfs:comment "Ethical Principle Examples",
			rdfs:comment "{beneficence, nonmaleficence, justice, autonomy, fidelity, veracity, fairness, civility, respect}" 
		SubClassOf: nep:EnumDataTypes
		
Class: nep:dilemma_mitigation_principles 
       Annotations:
			rdfs:comment "Dilemma Mitigation Principles",
			rdfs:comment "{ principle_of_double_effect, principle_of_triple_effect }"
	   SubClassOf: nep:EnumDataTypes

Class: nep:autonomous_action_principles 
       Annotations:
       rdfs:comment "Autonomous Action Principles",
       rdfs:comment "{ generalization_principle, principle_of_autonomy, principle_of_informed_consent, interference_principle }"
	   SubClassOf: nep:EnumDataTypes

DisjointClasses: nep:Norm, nep:EthicalTheory, nep:EthicalPrinciple,
		 nep:DilemmaMitigationPrinciple, nep:ActionRationale


Class: nep:Agent SubClassOf: tlo:Agent
       		 that tlo:is_member_of min 1 nep:SocialCollection
		  and tlo:enacts min 0 nep:AgentRole
		 
Class: nep:Robot     SubClassOf: nep:Agent
Class: nep:AgentRole SubClassOf: tlo:Role
       		     that nep:assigned_to min 0 nep:Agent
		      and nep:stipulates min 0 nep:Norm

Class: nep:Environment SubClassOf: tlo:Continuant
       		       that nep:is_perceived_by some nep:Agent
		        and inverse nep:is_perception_of min 1 nep:Situation
			
Class: nep:Situation   SubClassOf: tlo:Situation
       		       that inverse nep:recognizes some nep:Agent
		        and nep:is_perception_of some nep:Environment
			 
Class: nep:AgentPlan   SubClassOf: tlo:InformationArtifact
       		       that tlo:renders some tlo:Plan
		        and nep:subscribes_to some nep:EthicalTheory
			and nep:contains  min 1 nep:PlanAction
			and nep:satisfies min 1 nep:Norm

Class: nep:SituationPlanRepertoire SubClassOf: tlo:InformationArtifact
       			 that nep:includes min 1 nep:AgentPlan
			  and inverse nep:constrains_plans_for some nep:EthicalTheory
			  and inverse nep:features_described_in min 1 nep:Situation
			 
Class: nep:PlanAction  SubClassOf: tlo:InformationArtifact
       			 that tlo:renders some tlo:Method
			  and nep:is_implemented_by some nep:AgentAction

DisjointClasses: nep:AgentPlan, nep:SituationPlanRepertoire, nep:PlanAction


Class: nep:AgentAction	 SubClassOf: tlo:Process
       			 that tlo:affects some nep:Environment
			 
Class: nep:Derogation	 SubClassOf: tlo:Process

Class: nep:Explanation 	  SubClassOf: tlo:AgentCommunication
Class: nep:Query	  SubClassOf: tlo:AgentCommunication
       			  that inverse nep:initiates some nep:Agent
			   and inverse nep:receives  some nep:Agent

Class: nep:Answer	  SubClassOf: tlo:AgentCommunication
       			  that nep:is_response_to some nep:Query
			   and inverse nep:initiates some nep:Agent
			   and inverse nep:receives some nep:Agent
			  
Class: nep:TaskAssignment SubClassOf: tlo:AgentCommunication
       			  that nep:has_as_goal min 1 nep:Situation
			   and inverse nep:receives some nep:Agent

Class: nep:SocialCollection  SubClassOf: tlo:Collective
      			     that nep:influences_norm_applicability min 1 nep:Norm

Class: nep:Community 	 SubClassOf: nep:SocialCollection
Class: nep:Company 	 SubClassOf: nep:SocialCollection
Class: nep:Government 	 SubClassOf: nep:SocialCollection
Class: nep:Department 	 SubClassOf: nep:SocialCollection
Class: nep:Organization  SubClassOf: nep:SocialCollection
Class: nep:Team		 SubClassOf: nep:SocialCollection

DisjointClasses: nep:Community, nep:Company, nep:Government,
		 nep:Department, nep:Organization, nep:Team

Class: nep:team_types 
       Annotations:
			rdfs:comment "Team Types",
			rdfs:comment "{ self_directed_MAS_agents, human_directed }"
	   SubClassOf: nep:EnumDataTypes

Individual: nep:legal_norm   Types: nep:norm_category
Individual: nep:ethical_norm Types: nep:norm_category

Individual: nep:self_directed_team Types: nep:team_types
Individual: nep:human_directed     Types: nep:team_types

Individual: nep:activated      Types: nep:norm_states
Individual: nep:fulfilled      Types: nep:norm_states
Individual: nep:violated       Types: nep:norm_states
Individual: nep:expired	       Types: nep:norm_states
Individual: nep:suspended      Types: nep:norm_states
Individual: nep:not_applicable Types: nep:norm_states

Rule: nep:AgentRole( ?r), nep:Agent( ?a), tlo:enacts( ?a, ?r) -> nep:assigned_to( ?r, ?a)

Rule: nep:Situation( ?s),
      nep:Agent( ?a),
      nep:recognizes( ?a, ?s),
      tlo:AgentCommunication( ?ac),
      nep:prompts( ?s, ?ac) -> nep:initiates( ?a, ?ac)

Rule: nep:SituationPlanRepertoire( ?r),
      nep:Situation( ?s), nep:Agent( ?a),
      nep:features_described_in( ?s, ?r),
      nep:intends_to_realize( ?a, ?s) -> nep:selects_plans_from( ?a, ?r)

Rule: nep:SituationPlanRepertoire( ?r),
      nep:Situation( ?s), nep:Agent( ?a),
      nep:features_described_in( ?s, ?r),
      nep:recognizes( ?a, ?s) -> nep:selects_plans_from( ?a, ?r)

Rule: nep:Agent( ?a), nep:AgentPlan( ?ap), nep:PlanAction( ?pa),
      nep:AgentAction( ?ap),
      nep:Environment( ?e),
      nep:Situation( ?s),
      nep:is_perception_of( ?s, ?e),
      nep:is_perceived_by( ?e, ?a),
      nep:intends_to_realize( ?a, ?s),
      nep:contains( ?ap, ?pa),
      nep:is_implemented_by( ?pa, ?aa),
      tlo:affects( ?aa, ?e)
      -> nep:applies( ?a, ?ap), nep:executes( ?a, ?pa)

Rule: nep:Agent( ?a), nep:AgentPlan( ?ap), nep:PlanAction( ?pa),
      nep:AgentAction( ?ap),
      nep:Environment( ?e),
      nep:Situation( ?s),
      nep:is_perception_of( ?s, ?e),
      nep:is_perceived_by( ?e, ?a),
      nep:recognizes( ?a, ?s),
      nep:contains( ?ap, ?pa),
      nep:is_implemented_by( ?pa, ?aa),
      tlo:affects( ?aa, ?e)
      -> nep:applies( ?a, ?ap), nep:executes( ?a, ?pa)

Rule: nep:Norm( ?n),
      nep:Derogation( ?d),
      nep:AgentAction( ?a),
      nep:activates( ?a, ?d),
      nep:temporarily_suspends( ?d, ?n)
      -> nep:state( ?n, nep:suspended)

Rule: nep:Norm( ?n),
      nep:state( ?n, nep:suspended),
      nep:Derogation( ?d),
      nep:AgentAction( ?a),
      nep:deactivates( ?a, ?d)
      -> nep:state( ?n, nep:activated)

