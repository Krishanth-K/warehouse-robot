<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://test.org/warehouse_ethics.owl"
         xmlns="http://test.org/warehouse_ethics.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://test.org/warehouse_ethics.owl"/>

<owl:ObjectProperty rdf:about="#has_proximity">
  <rdfs:domain rdf:resource="#Robot"/>
  <rdfs:range rdf:resource="#Proximity"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Entity">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Human">
  <rdfs:subClassOf rdf:resource="#Entity"/>
</owl:Class>

<owl:Class rdf:about="#Robot">
  <rdfs:subClassOf rdf:resource="#Entity"/>
</owl:Class>

<owl:Class rdf:about="#Proximity">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Near">
  <rdfs:subClassOf rdf:resource="#Proximity"/>
</owl:Class>

<owl:Class rdf:about="#Far">
  <rdfs:subClassOf rdf:resource="#Proximity"/>
</owl:Class>

<owl:Class rdf:about="#Behavior">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#NormalSpeed">
  <rdfs:subClassOf rdf:resource="#Behavior"/>
</owl:Class>

<owl:Class rdf:about="#ReducedSpeed">
  <rdfs:subClassOf rdf:resource="#Behavior"/>
</owl:Class>

<owl:Class rdf:about="#EmergencyStop">
  <rdfs:subClassOf rdf:resource="#Behavior"/>
</owl:Class>

<swrl:Variable rdf:about="urn:swrl#r"/>

<swrl:Variable rdf:about="urn:swrl#p"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Robot"/>
          <swrl:argument1 rdf:resource="urn:swrl#r"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#has_proximity"/>
              <swrl:argument1 rdf:resource="urn:swrl#r"/>
              <swrl:argument2 rdf:resource="urn:swrl#p"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:ClassAtom>
                  <swrl:classPredicate rdf:resource="#Near"/>
                  <swrl:argument1 rdf:resource="urn:swrl#p"/>
                </swrl:ClassAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#ReducedSpeed"/>
          <swrl:argument1 rdf:resource="urn:swrl#r"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
